[Unit]
Description=Frankenstein Next.js Frontend
After=network.target

[Service]
User=deploy
WorkingDirectory=/var/www/frankenstein-hub/frontend
Environment="NODE_ENV=production"
Environment="PORT=3000"
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
