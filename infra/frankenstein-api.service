[Unit]
Description=Frankenstein Rust Axum API
After=network.target postgresql.service

[Service]
User=deploy
WorkingDirectory=/var/www/frankenstein-hub/backend
ExecStart=/home/deploy/.cargo/bin/cargo run --release
EnvironmentFile=/var/www/frankenstein-hub/backend/.env
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
