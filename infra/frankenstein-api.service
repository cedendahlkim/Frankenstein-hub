[Unit]
Description=Frankenstein Rust Axum API
After=network.target postgresql.service

[Service]
User=root
WorkingDirectory=/var/www/frankenstein-hub/backend
ExecStart=/var/www/frankenstein-hub/backend/target/release/frankenstein_api
EnvironmentFile=/var/www/frankenstein-hub/backend/.env
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
